{
  "name": "velomark",
  "version": "0.1.1",
  "private": false,
  "description": "Solid-only markdown rendering tuned for streamed AI responses.",
  "keywords": [
    "ai",
    "markdown",
    "solid",
    "streaming"
  ],
  "homepage": "https://github.com/sakti-dev/velomark#readme",
  "bugs": {
    "url": "https://github.com/sakti-dev/velomark/issues"
  },
  "license": "MIT",
  "author": "sakti-dev",
  "contributors": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sakti-dev/velomark.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "browser": {},
  "types": "./dist/index.d.ts",
  "typesVersions": {},
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vp dev dev",
    "build": "tsup && cp src/theme/styles.css dist/styles.css",
    "test": "concurrently pnpm:test:client pnpm:test:ssr pnpm:test:packed-consumer",
    "test:client": "vp test run --config vitest.config.ts",
    "test:coverage": "vp test run --workspace vitest.coverage.workspace.ts --coverage",
    "test:ssr": "vp test run --config vitest.ssr.config.ts --mode ssr",
    "test:packed-consumer": "node ./scripts/pack-and-test-consumer.mjs",
    "prepublishOnly": "pnpm build",
    "format": "ultracite fix",
    "lint": "concurrently pnpm:lint:*",
    "lint:code": "ultracite check",
    "lint:types": "tsc --noEmit",
    "update-deps": "pnpm up -Li",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@shikijs/core": "^3.22.0",
    "katex": "^0.16.38",
    "mermaid": "^11.12.3",
    "shiki": "^3.22.0",
    "shiki-stream": "^0.1.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^20.12.12",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^8.2.2",
    "esbuild": "^0.21.3",
    "esbuild-plugin-solid": "^0.6.0",
    "eslint": "^8.56.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-no-only-tests": "^3.1.0",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.5.2",
    "prettier": "3.0.0",
    "solid-js": "^1.9.10",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.0.2",
    "tsup-preset-solid": "^2.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.4.5",
    "ultracite": "7.2.5",
    "vite": "catalog:",
    "vite-plugin-solid": "^2.10.2",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "solid-js": "^1.9.10"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.5.3"
}
